NODE_ENV=development
PORT=3000

# PostgreSQL connection
DATABASE_URL=postgresql://zyvia:zyvia@localhost:5432/zyvia

# S3-compatible object store (MinIO locally)
OBJECT_STORE_ENDPOINT=http://localhost:9000
OBJECT_STORE_BUCKET=health-records
OBJECT_STORE_ACCESS_KEY=minioadmin
OBJECT_STORE_SECRET_KEY=minioadmin
OBJECT_STORE_REGION=us-east-1

# JWT verification — path to RS256 public key PEM file
JWT_PUBLIC_KEY_PATH=./keys/dev-public.pem

# JWT signing — required for auth token issuance (login/register)
JWT_PRIVATE_KEY_PATH=./keys/dev-private.pem

# Anthropic API key for AI medical responses
ANTHROPIC_API_KEY=sk-ant-your-key-here
